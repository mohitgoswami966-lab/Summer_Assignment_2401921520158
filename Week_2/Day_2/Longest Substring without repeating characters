class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        vector<int> last(256, -1);
        int l = 0, maxLen = 0;
        for (int r = 0; r < s.size(); r++) {
            l = max(l, last[s[r]] + 1);
            last[s[r]] = r;
            maxLen = max(maxLen, r - l + 1);
        }
        return maxLen;
    }
};
