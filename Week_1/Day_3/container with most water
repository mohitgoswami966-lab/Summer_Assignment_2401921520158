class Solution {
public:
    int maxArea(vector<int>& height) {
        int MaxArea=0;
        int n=height.size();
        int i=0,j=n-1;
        while(i<j){
            MaxArea=max(MaxArea,(j-i)*min(height[i],height[j]));
            if(height[i]<height[j]){
                i++;
            }
            else{
                j--;
            }
        }
        return MaxArea;
    }
};
