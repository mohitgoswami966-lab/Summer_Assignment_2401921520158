class Solution {
public:
    vector<vector<int>> matrixReshape(vector<vector<int>>& mat, int r, int c) {
        int row=mat.size();
        int col=mat[0].size();
        vector<vector<int>> result(r,vector<int>(c));
        if(row*col != r*c){
            return mat;
        }
        for(int i=0;i<row*col;i++){
            result[i/c][i%c]=mat[i/col][i%col];
        }
        return result;
    }
};
