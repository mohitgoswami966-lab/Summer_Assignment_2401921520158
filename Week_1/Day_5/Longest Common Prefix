class Solution {
public:
    string longestCommonPrefix(vector<string>& strs) {
        string ans="";
        int n=strs.size();
        sort(strs.begin(),strs.end());
        string left=strs[0];
        string right=strs[n-1];
        for(int i=0;i<min(left.size(),right.size());i++){
            if(left[i]!=right[i]){
                return ans;
            }
            else{
                ans +=left[i];
            }
        }
        return ans;
    }
};
