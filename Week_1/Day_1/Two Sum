class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int,int> Map;
        int n=nums.size();
        for(int i=0;i<n;i++){
            Map[nums[i]]=i;
        }
        for(int i=0;i<n;i++){
            int needed=target-nums[i];
            if(Map.count(needed) && Map[needed]!=i){
                return {i,Map[needed]};
            }
        }
        return {};
    }
};
